    "# Bir kullanıcıya film öner\n",
    "def film_oner(user_id, kac_film=5):\n",
    "    # Kullanıcıya en benzer 10 kullanıcıyı bul\n",
    "    benzer_kullanicilar = user_similarity_df[user_id].sort_values(ascending=False)[1:11].index\n",
    "    \n",
    "    # Bu kullanıcıların izlediği filmleri al\n",
    "    kullanicinin_izledikleri = set(train_data[train_data[\"user_id\"] == user_id][\"item_id\"])\n",
    "    \n",
    "    # Benzer kullanıcıların yüksek puan verdiği filmleri bul\n",
    "    oneriler = train_data[\n",
    "        (train_data[\"user_id\"].isin(benzer_kullanicilar)) &\n",
    "        (~train_data[\"item_id\"].isin(kullanicinin_izledikleri)) &\n",
    "        (train_data[\"rating\"] >= 4)\n",
    "    ]\n",
    "    \n",
    "    # En çok önerilen filmleri sırala\n",
    "    oneri_listesi = oneriler.groupby(\"item_id\")[\"rating\"].mean().sort_values(ascending=False).head(kac_film)\n",
    "    oneri_listesi = oneri_listesi.reset_index().merge(movies[[\"item_id\", \"title\"]], on=\"item_id\")\n",
    "    \n",
    "    return oneri_listesi\n",
    "\n",
    "# 1 numaralı kullanıcıya 5 film öner\n",
    "sonuc = film_oner(user_id=1, kac_film=5)\n",
    "print(\"Kullanıcı 1 için önerilen filmler:\")\n",
    "print(sonuc[[\"title\", \"rating\"]])"
   ]
