    "from sklearn.metrics import mean_squared_error\n",
    "import numpy as np\n",
    "\n",
    "def puan_tahmin_et(user_id, item_id):\n",
    "    if item_id not in user_movie_matrix.columns:\n",
    "        return user_movie_matrix.loc[user_id].mean()\n",
    "    \n",
    "    benzer_kullanicilar = user_similarity_df[user_id].sort_values(ascending=False)[1:11]\n",
    "    \n",
    "    agirlikli_puan = 0\n",
    "    toplam_agirlik = 0\n",
    "    \n",
    "    for benzer_id, benzerlik in benzer_kullanicilar.items():\n",
    "        puan = user_movie_matrix.loc[benzer_id, item_id]\n",
    "        if puan > 0:\n",
    "            agirlikli_puan += benzerlik * puan\n",
    "            toplam_agirlik += benzerlik\n",
    "    \n",
    "    if toplam_agirlik == 0:\n",
    "        return user_movie_matrix.loc[user_id].mean()\n",
    "    \n",
    "    return agirlikli_puan / toplam_agirlik\n",
    "\n",
    "# Test verisinden 500 örnek al ve RMSE hesapla\n",
    "test_sample = test_data[test_data[\"user_id\"].isin(user_movie_matrix.index)].sample(500, random_state=42)\n",
    "\n",
    "gercek = []\n",
    "tahmin = []\n",
    "\n",
    "for _, row in test_sample.iterrows():\n",
    "    gercek.append(row[\"rating\"])\n",
    "    tahmin.append(puan_tahmin_et(row[\"user_id\"], row[\"item_id\"]))\n",
    "\n",
    "rmse = np.sqrt(mean_squared_error(gercek, tahmin))\n",
    "print(f\"RMSE: {rmse:.4f}\")\n",
    "print(\"(RMSE ne kadar düşükse model o kadar iyi)\")"
   ]
