   "source": [
    "from sklearn.metrics.pairwise import cosine_similarity\n",
    "\n",
    "# Kullanıcı-film matrisini oluştur\n",
    "user_movie_matrix = train_data.pivot_table(\n",
    "    index=\"user_id\", \n",
    "    columns=\"item_id\", \n",
    "    values=\"rating\"\n",
    ").fillna(0)\n",
    "\n",
    "# Kullanıcılar arası benzerliği hesapla\n",
    "user_similarity = cosine_similarity(user_movie_matrix)\n",
    "user_similarity_df = pd.DataFrame(\n",
    "    user_similarity,\n",
    "    index=user_movie_matrix.index,\n",
    "    columns=user_movie_matrix.index\n",
    ")\n",
    "\n",
    "print(\"Kullanıcı-film matrisi oluşturuldu!\")\n",
    "print(f\"Matris boyutu: {user_movie_matrix.shape}\")\n",
    "print(\"Benzerlik matrisi hazır!\")"
   ]
  },
